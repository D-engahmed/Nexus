' ---------------------------------------------------------------------
' LEVEL 4: DEPLOYMENT DIAGRAM
' Shows the deployment architecture across regions and availability zones
' ---------------------------------------------------------------------
title C4 Model - Level 4: Deployment Diagram

Deployment_Node(aws_primary, "AWS Production", "Primary Region (us-east-1)") {
    Deployment_Node(aws_az1, "Availability Zone 1", "us-east-1a") {
        Deployment_Node(k8s_node1, "Kubernetes Node 1", "m6g.2xlarge") {
            Container_Instance(api_gateway_inst, "API Gateway Pod", "Kong", "Handles API traffic")
            Container_Instance(order_service_inst, "Order Service Pod", "Go/Spring Boot", "Manages orders")
            Container_Instance(payment_service_inst, "Payment Service Pod", "Go/Spring Boot", "Processes payments")
            Container_Instance(delivery_service_inst, "Delivery Service Pod", "Go/Spring Boot", "Manages deliveries")
            Container_Instance(dispatch_service_inst, "Dispatch Service Pod", "Go/Spring Boot", "Routes orders")
            Container_Instance(redis_inst, "Redis Cache Pod", "Redis", "Caching layer")
        }
        Deployment_Node(db_primary, "Database Primary", "db.r6g.2xlarge") {
            Container_Instance(postgres_primary, "PostgreSQL Primary", "PostgreSQL 16", "Primary database")
        }
        Deployment_Node(kafka_primary, "Kafka Broker 1", "kafka.m6g.2xlarge") {
            Container_Instance(kafka_broker1, "Kafka Broker 1", "Kafka 3.x", "Message broker")
        }
    }
    Deployment_Node(aws_az2, "Availability Zone 2", "us-east-1b") {
        Deployment_Node(k8s_node2, "Kubernetes Node 2", "m6g.2xlarge") {
            Container_Instance(merchant_service_inst, "Merchant Service Pod", "Go/Spring Boot", "Manages merchants")
            Container_Instance(driver_service_inst, "Driver Service Pod", "Go/Spring Boot", "Manages drivers")
            Container_Instance(notification_service_inst, "Notification Service Pod", "Node.js/Go", "Sends notifications")
            Container_Instance(analytics_service_inst, "Analytics Service Pod", "Python/Go", "Analytics and reporting")
            Container_Instance(admin_service_inst, "Admin Service Pod", "Go/Spring Boot", "Admin operations")
            Container_Instance(redis_replica_inst, "Redis Cache Replica", "Redis", "Read replica")
        }
        Deployment_Node(db_replica1, "Database Replica 1", "db.r6g.2xlarge") {
            Container_Instance(postgres_replica1, "PostgreSQL Replica 1", "PostgreSQL 16", "Read replica")
        }
        Deployment_Node(kafka_secondary, "Kafka Broker 2", "kafka.m6g.2xlarge") {
            Container_Instance(kafka_broker2, "Kafka Broker 2", "Kafka 3.x", "Message broker")
        }
    }
    Deployment_Node(aws_az3, "Availability Zone 3", "us-east-1c") {
        Deployment_Node(k8s_node3, "Kubernetes Node 3", "m6g.2xlarge") {
            Container_Instance(integration_service_inst, "Integration Service Pod", "Go/Python", "Third-party integrations")
            Container_Instance(auth_service_inst, "Auth Service Pod", "Go/Spring Boot", "Authentication")
        }
        Deployment_Node(db_replica2, "Database Replica 2", "db.r6g.2xlarge") {
            Container_Instance(postgres_replica2, "PostgreSQL Replica 2", "PostgreSQL 16", "Read replica")
        }
        Deployment_Node(kafka_tertiary, "Kafka Broker 3", "kafka.m6g.2xlarge") {
            Container_Instance(kafka_broker3, "Kafka Broker 3", "Kafka 3.x", "Message broker")
        }
    }
    Deployment_Node(load_balancer, "Load Balancer", "AWS ALB") {
        Container_Instance(alb_inst, "Application Load Balancer", "ALB", "Distributes traffic")
    }
    Deployment_Node(s3_storage, "Object Storage", "AWS S3") {
        Container_Instance(s3_bucket, "S3 Bucket", "S3", "Static assets, backups")
    }
    Deployment_Node(elasticsearch_cluster, "Elasticsearch Cluster", "ES 8.x") {
        Container_Instance(es_node1, "ES Node 1", "Elasticsearch 8.x", "Search and logs")
        Container_Instance(es_node2, "ES Node 2", "Elasticsearch 8.x", "Search and logs")
        Container_Instance(es_node3, "ES Node 3", "Elasticsearch 8.x", "Search and logs")
    }
}

Deployment_Node(aws_dr, "AWS DR Region", "Secondary Region (us-west-2)") {
    Deployment_Node(dr_k8s, "DR Kubernetes", "Replica Cluster") {
        Container_Instance(dr_api_gateway, "API Gateway DR Pod", "Kong", "Failover API gateway")
        Container_Instance(dr_order_service, "Order Service DR Pod", "Go/Spring Boot", "Failover order service")
        Container_Instance(dr_payment_service, "Payment Service DR Pod", "Go/Spring Boot", "Failover payment service")
        Container_Instance(dr_db, "Database DR", "db.r6g.2xlarge", "Replicated database")
        Container_Instance(dr_kafka, "Kafka DR Broker", "kafka.m6g.2xlarge", "Replicated broker")
    }
}

