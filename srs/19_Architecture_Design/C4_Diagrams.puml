title C4 Model - Level 3: Component Diagram - Order Service

Container(order_service_component, "Order Service", "Go / Spring Boot", "Manages order lifecycle and fulfillment")

System_Boundary(order_service_boundary, "Order Service") {
    Component(order_api, "Order API Controller", "REST Controller", "Handles HTTP requests for order operations")
    Component(order_validator, "Order Validator", "Validation Service", "Validates order data, availability, eligibility")
    Component(order_orchestrator, "Order Orchestrator", "Orchestration Service", "Orchestrates order creation and status transitions")
    Component(order_state_machine, "Order State Machine", "State Machine", "Manages order state transitions with business rules")
    Component(order_repository, "Order Repository", "Data Access", "Persistence operations for orders and order items")
    Component(order_cache, "Order Cache", "Redis Client", "Caches order data for fast retrieval")
    Component(order_publisher, "Order Event Publisher", "Kafka Producer", "Publishes order events to the message bus")
    Component(order_consumer, "Order Event Consumer", "Kafka Consumer", "Consumes payment and delivery events")
    Component(order_tracking, "Order Tracking Service", "Tracking Service", "Manages real-time order tracking")
    Component(timeline_service, "Timeline Service", "Timeline Service", "Manages order timeline and history")
}

