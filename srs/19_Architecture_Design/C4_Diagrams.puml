title C4 Model - Dynamic Diagram: Delivery Tracking Sequence

Person(customer_track, "Customer", "Tracks delivery")
Container(delivery_service_track, "Delivery Service", "Manages deliveries")
Container(driver_service_track, "Driver Service", "Manages drivers")
Container(message_bus_track, "Message Bus", "Event streaming")
Container(cache_track, "Cache Layer", "Redis")
Container(websocket_track, "WebSocket Gateway", "Real-time updates")

Rel(customer_track, websocket_track, "1. Opens WebSocket connection", "WSS")
Rel(driver_service_track, message_bus_track, "2. Sends location updates", "Kafka")
Rel(message_bus_track, delivery_service_track, "3. Consumes location events", "Kafka")
Rel(delivery_service_track, cache_track, "4. Caches location", "Redis")
Rel(delivery_service_track, websocket_track, "5. Pushes location updates", "WSS")
Rel(websocket_track, customer_track, "6. Updates live map", "WSS")
Rel(delivery_service_track, message_bus_track, "7. Publishes ETA updates", "Kafka")
Rel(message_bus_track, websocket_track, "8. Pushes ETA updates", "WSS")
Rel(websocket_track, customer_track, "9. Updates ETA display", "WSS")

@enduml